{
  "name": "@typedbywill/nexo",
  "version": "1.0.0",
  "description": "Declarative AI-native frontend runtime for landing pages and microsystems.",
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/typedbywill/nexo.git"
  },
  "homepage": "https://github.com/typedbywill/nexo#readme",
  "bugs": {
    "url": "https://github.com/typedbywill/nexo/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "build": "tsup && chmod +x dist/cli/index.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "test:watch": "vitest --watch",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "nexo",
    "frontend",
    "runtime",
    "web-components",
    "shadow-dom",
    "declarative",
    "static-site",
    "cli"
  ],
  "author": "typedbywill",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "chokidar": "^5.0.0",
    "mime-types": "^3.0.2",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/jsdom": "^28.0.3",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "bin": {
    "nexo": "dist/cli/index.js"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix"
    ],
    "*.{ts,js,json,md}": [
      "prettier --write"
    ]
  }
}
